%% B.25 --- Moving-Knife Redistricting
%% References

%% ===================================================================
%% FAIR DIVISION
%% ===================================================================

@article{dubins1961,
  author  = {Dubins, Lester E. and Spanier, Edwin H.},
  title   = {How to Cut a Cake Fairly},
  journal = {American Mathematical Monthly},
  volume  = {68},
  number  = {1},
  pages   = {1--17},
  year    = {1961},
  doi     = {10.2307/2311357},
  note    = {Introduces the moving-knife protocol for fair division of a
             heterogeneous resource among $n$ parties. Proves proportionality
             and envy-freeness of the continuous knife-sweep procedure.
             B.25 adapts this protocol to redistricting by replacing the
             linear knife sweep with an angular orientation sweep, evaluated
             for Reock compactness at each orientation.},
}

@article{puppe2026,
  author  = {Puppe, Clemens and Tasnadi, Attila},
  title   = {Moving-Knife Redistricting},
  journal = {Public Choice},
  year    = {2026},
  note    = {Formalises the moving-knife protocol for redistricting.
             Proves that any procedure satisfying anonymity, population balance,
             and compactness maximisation is uniquely characterised by a
             moving-knife angular sweep.
             B.25 is the computational implementation and empirical evaluation
             of the Puppe-Tasnadi proposal.
             Forthcoming; preprint available from corresponding author on request},
}

%% ===================================================================
%% COMPACTNESS MEASURES
%% ===================================================================

@article{reock1961,
  author  = {Reock, Ernest C.},
  title   = {A Note: Measuring Compactness as a Requirement of Legislative
             Apportionment},
  journal = {Midwest Journal of Political Science},
  volume  = {5},
  number  = {1},
  pages   = {70--74},
  year    = {1961},
  doi     = {10.2307/2109043},
  note    = {Introduces Reock compactness: the ratio of district area to the
             area of the minimum enclosing circle. The measure has become the
             most frequently cited compactness metric in redistricting litigation
             in the United States, cited by courts in North Carolina, Wisconsin,
             Florida, and Georgia. B.25 \mka{} directly maximises this measure.},
}

%% ===================================================================
%% MINIMUM ENCLOSING CIRCLE
%% ===================================================================

@incollection{welzl1991,
  author    = {Welzl, Emo},
  title     = {Smallest Enclosing Disks (Balls and Ellipsoids)},
  booktitle = {New Results and New Trends in Computer Science},
  editor    = {Maurer, Hermann},
  series    = {Lecture Notes in Computer Science},
  volume    = {555},
  pages     = {359--370},
  publisher = {Springer},
  year      = {1991},
  doi       = {10.1007/BFb0038202},
  note      = {Presents the randomised incremental algorithm for computing the
               minimum enclosing circle of a set of $m$ points in expected $O(m)$
               time. Used in B.25 \mka{} to compute Reock scores at each
               orientation of the sweep. The expected-$O(m)$ bound is essential
               to keeping the total sweep runtime at $O(n_{\mathrm{orient}} \times m)$.},
}

