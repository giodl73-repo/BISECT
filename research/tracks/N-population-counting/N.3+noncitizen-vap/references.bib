  title = {377 U.S. 533 (1964)},
  howpublished = {Supreme Court of the United States},
  year = {1964},
  note = {84 S. Ct. 1362. One person, one vote: legislative districts must have approximately equal population. Does not specify which population.}
}

@misc{burns1966,
  author = {{Burns v. Richardson}},
  title = {384 U.S. 73 (1966)},
  howpublished = {Supreme Court of the United States},
  year = {1966},
  note = {86 S. Ct. 1286. Hawaii permitted to use registered voters as redistricting base to exclude non-resident military. Transience key to permissibility. Leading precedent for non-total-population state redistricting bases.}
}

