@article{polsby1991,
  author  = {Polsby, Daniel D. and Popper, Robert D.},
  title   = {The Third Criterion: Compactness as a Procedural Safeguard
             Against Partisan Gerrymandering},
  journal = {Yale Law and Policy Review},
  volume  = {9},
  number  = {2},
  pages   = {301--353},
  year    = {1991},
  note    = {Polsby-Popper compactness ratio $\mathrm{PP} = 4\pi A / P^2$.
             U.7 uses edge cuts (\EC) as the compactness objective rather
             than Polsby-Popper. Edge cuts are the natural graph-theoretic
             compactness measure; they are monotonically related to boundary
             length and are computationally tractable as an optimisation
             objective. The Pareto front over \EC{} does not directly produce
             Polsby-Popper-optimal plans; practitioners who require PP
             optimality should consult the \EC{}-to-PP relationship
             established in B.2.},
}
