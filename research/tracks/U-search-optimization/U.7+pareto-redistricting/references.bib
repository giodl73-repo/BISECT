@misc{dellaLibera2026smc,
  author = {Della-Libera, Gio},
  title  = {Sequential Monte Carlo for Redistricting:
            Calibrated Plan Ensembles via Importance Sampling},
  year   = {2026},
  note   = {G.7 in Algorithmic Redistricting series.
